# Terraform state and plan files
*.tfstate
*.tfstate.*
.terraform/

# Only root configs are init'd; a lock file under modules/ is a stray
# from `terraform init` in a child-module dir, not a committed lock.
modules/**/.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Sensitive tfvars — terraform.tfvars is committed for non-sensitive values
*.secrets.tfvars
*.secrets.tfvars.json
terraform.local.tfvars
terraform.local.tfvars.json
*.local.auto.tfvars
*.local.auto.tfvars.json
!example.tfvars

# Local value overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json
!example_override.tf

# Plan output files
*tfplan*

# IDE
.idea/
.vscode/
*.swp
*.swo
